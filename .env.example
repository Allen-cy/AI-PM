# Local corpus build only. The generated snapshot is committed for deployment.
AI_PMO_KB_PATH=/absolute/path/to/AI-PMO-SYS

# Existing optional providers. Never commit real values.
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
GLM_API_KEY=
GLM_MODEL=glm-4.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App auth. Keep disabled until Supabase schema + admin seed are ready in the target environment.
AUTH_REQUIRED=false
AUTH_SESSION_SECRET=
CRON_SECRET=
# Internal production audit endpoint token. Server-only, long random value.
P17P25_AUDIT_TOKEN=
REGISTRATION_CODE_PEPPER=
# Recommended: a dedicated 32+ character server-only root key for user AI/Feishu credentials.
# If omitted, AUTH_SESSION_SECRET is used. Never expose these as NEXT_PUBLIC_* variables.
CREDENTIAL_ENCRYPTION_KEY=
CREDENTIAL_ENCRYPTION_KEY_VERSION=1
# During key rotation keep old roots as CREDENTIAL_ENCRYPTION_KEY_V1, _V2, etc.
# CREDENTIAL_ENCRYPTION_KEY_V1=
ADMIN_EMAIL=
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_NAME=系统管理员

# SMTP provider for registration-code emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Server-only Feishu app identity and Base mapping.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_TOKEN=
FEISHU_PROJECT_TABLE_ID=
FEISHU_MILESTONE_TABLE_ID=
FEISHU_TASK_TABLE_ID=
FEISHU_RISK_TABLE_ID=
FEISHU_CONTRACT_TABLE_ID=
FEISHU_PAYMENT_TABLE_ID=
FEISHU_COST_TABLE_ID=
FEISHU_SYNC_LEDGER_TABLE_ID=

# Feishu callback verification. Keep encrypted callbacks disabled unless a verified decryptor is added.
FEISHU_VERIFICATION_TOKEN=
FEISHU_EVENT_ALLOWED_TYPES=im.message.receive_v1

# Protects POST /api/integrations/feishu/actions. Generate a long random server-only value.
AI_PM_INTEGRATION_API_KEY=

# Optional shared folder for Bot-created PMO documents.
FEISHU_DOCUMENT_PARENT_TOKEN=
FEISHU_DOCUMENT_GRANT_OPEN_ID=
